if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/runner/work/mantine-react-table/mantine-react-table/node_modules/.pnpm/size-limit@11.1.6/node_modules/size-limit/node_modules:/home/runner/work/mantine-react-table/mantine-react-table/node_modules/.pnpm/size-limit@11.1.6/node_modules:/home/runner/work/mantine-react-table/mantine-react-table/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/runner/work/mantine-react-table/mantine-react-table/node_modules/.pnpm/size-limit@11.1.6/node_modules/size-limit/node_modules:/home/runner/work/mantine-react-table/mantine-react-table/node_modules/.pnpm/size-limit@11.1.6/node_modules:/home/runner/work/mantine-react-table/mantine-react-table/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../size-limit/bin.js" "$@"
else
  exec node  "$basedir/../size-limit/bin.js" "$@"
fi
